{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Killport",
  "identifier": "com.killport.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'ipc:' https://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "createUpdaterArtifacts": true,
    "publisher": "episuarez",
    "copyright": "Copyright © 2025 episuarez",
    "category": "DeveloperTool",
    "shortDescription": "Kill and manage TCP port processes",
    "longDescription": "Windows developer tool for managing TCP port processes. List what is listening, kill it, or restart it — with enough context to know what you are hitting.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/episuarez/killport/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQzNzRFMjA2NzFGNjdFOTkKUldTWmZ2WnhCdUowUTBXdUpJTkJCU0p6ZEZGaEdSeEk5VnhtZStiZkFJL0pVODFJL0ZDZDdZNVoK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
